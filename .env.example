# ============================================
# TATUA GATEWAY - Environment Configuration
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Your Daraja Credentials (from developer.safaricom.co.ke)
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here
DARAJA_ENVIRONMENT=sandbox

# Your public server URL (where Safaricom sends callbacks)
# In development use ngrok: https://abc123.ngrok.io
# In production use your real domain: https://gateway.tatua.co.ke
GATEWAY_BASE_URL=https://your-public-url.com

# Admin secret for internal management endpoints
ADMIN_SECRET=change_this_to_a_strong_random_string
